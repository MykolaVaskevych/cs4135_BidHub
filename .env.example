# BidHub environment configuration
# Copy this file to `.env` (in the same directory) before running `docker compose up`.
# `.env` is git-ignored. Replace every value below before deploying outside local dev.

# ─── JWT signing secret ──────────────────────────────────────────────────
# Required. Minimum 32 characters. Used by api-gateway and account-service to
# sign and verify access tokens. Rotate this for every environment.
JWT_SECRET=replace-me-with-a-strong-random-secret-at-least-32-chars

# ─── PostgreSQL credentials ──────────────────────────────────────────────
# Required. Used by the postgres container itself and by every service that
# connects to it (account, auction, admin, notification, delivery).
POSTGRES_USER=bidhub
POSTGRES_PASSWORD=replace-me-with-a-strong-random-password

# ─── Internal service-to-service token ───────────────────────────────────
# Required. Shared secret that the api-gateway attaches to every proxied
# request. Currently only account-service verifies it; extending the same
# check to the other backend services is tracked as future work.
INTERNAL_API_TOKEN=replace-me-with-another-strong-random-token

# ─── RabbitMQ credentials ────────────────────────────────────────────────
# Required. Used by the rabbitmq container itself and by every service that
# publishes or consumes settlement-saga events (auction, payment, order,
# delivery). Management UI is at http://localhost:15672.
RABBITMQ_USER=bidhub
RABBITMQ_PASS=replace-me-with-a-strong-random-password

# ─── CORS origins (comma-separated) ──────────────────────────────────────
# Optional. Defaults cover the dockerized frontend (http://localhost) and the
# Vite dev server (http://localhost:5173). Add deployed origins here.
CORS_ORIGINS=http://localhost,http://localhost:5173
